.container {
  background-color: #f6f6f6;
  padding: 20px;
  font-family: Arial, sans-serif;
}

.header {
  text-align: center;
  margin-bottom: 20px;
}

.logo {
  color: #f44a40;
  font-size: 24px;
  font-weight: bold;
}

.subtitle {
  color: #666;
  font-size: 14px;
}

.profile {
  text-align: center;
  padding: 20px;
  background-color: #ffffff;
  border-radius: 10px;
  margin-bottom: 20px;
  width: 750rpx;
}

.avatar {
  width: 80px;
  height: 80px;
  background-color: #ddd;
  border-radius: 50%;
  margin: 0 auto 10px;
}

.name {
  font-size: 18px;
  font-weight: bold;
}

.university {
  font-size: 16px;
  
  color: #666;
}

.menu {
  background-color: #ffffff;
  border-radius: 10px;
  overflow: hidden;
  width: 750rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 15px;
  border-bottom: 1px solid #eee;
}

.menu-item:last-child {
  border-bottom: none;
}
.exit-item{
  display: flex;
  align-items: center;
  padding: 15px;
  color: #f44a40;
  border-bottom: 1px solid #eee;
}
.icon {
  width: 24px;
  height: 24px;
  margin-right: 10px;
}

.value, .action {
  margin-left: auto;
  color: #999;
  font-size: 14px;
}
