/**app.wxss**/
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
} 
.menu {
  background-color: #ffffff;
  border-radius: 10px;
  overflow: hidden;
  width: 750rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 15px;
  border-bottom: 1px solid #eee;
}

.menu-item:last-child {
  border-bottom: none;
}
